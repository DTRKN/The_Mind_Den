# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=123456789

# AI — OpenRouter (OpenAI-совместимый API, поддерживает сотни моделей)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Примеры моделей: anthropic/claude-3.5-sonnet | openai/gpt-4o | google/gemini-2.0-flash
MODEL=minimax/minimax-m2.5

# Groq (голосовая транскрипция аудио → текст через Whisper large-v3-turbo)
GROQ_API_KEY=your_groq_api_key_here

# Файловый workspace (агент работает только внутри этой папки)
WORKSPACE_DIR=./workspace

# Параметры агента
HISTORY_LIMIT=20
VECTOR_SEARCH_LIMIT=5

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000